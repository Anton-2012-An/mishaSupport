            },
            { 
                title: "💡 РАЗВИТИЕ КАНАЛА", 
                content: "Для того, чтобы поучаствовать в развитии канала, надо отправить в чат \"Идея для чего+текст идеи\"", 
                date: "Постоянная рубрика" 
            }
        ];
        let newsHtml = `<div style="margin-bottom: 12px;"><button class="back-btn" id="backFromNewsBtn">◀ Назад в меню</button></div>`;
        newsHtml += `<div style="max-height: 450px; overflow-y: auto; padding-right: 5px;">`;
        newsItems.forEach(item => {
            newsHtml += `
                <div class="news-item">
                    <div class="news-title">${escapeHtml(item.title)}</div>
                    <div>${escapeHtml(item.content)}</div>
                    <div class="news-date">📅 ${escapeHtml(item.date)}</div>
                </div>
            `;
        });
        newsHtml += `</div>`;
        return newsHtml;
    }

    // ---------- ЗАЯВКИ (ОТДЕЛЬНАЯ ПАПКА) ----------
    // Собираем все заявки из разных частей системы в одном месте
    function getRequestsHtml() {
        // Шаблоны заявок согласно ТЗ
        const requestsList = [
            {
                title: "📝 Заявка №1 (Модератор / Админ канала)",
                description: "Для подачи заявки на модератора (или админа) отправьте сообщение в чат канала по следующему шаблону:",
                template: "Заявка №1+насколько заинтересованы в этом+количество лет",
                note: "Пример: Заявка №1+очень заинтересован, хочу помогать+16 лет"
            },
            {
                title: "📝 Заявка №2 (Агент поддержки)",
                description: "Чтобы стать агентом поддержки, отправьте в чат:",
                template: "Заявка №2+причина почему хотите им стать+насколько сильно заинтересованы в этом+количество лет",
                note: "Пример: Заявка №2+люблю помогать подписчикам+очень сильно+17 лет"
            },
            {
                title: "📝 Заявка №3 (Вопрос / Другое)",
                description: "Если у вас есть вопрос, которого нет в списке, или вы хотите что-то предложить:",
                template: "заявка №3+вопрос",
                note: "Пример: заявка №3+Как попасть на закрытый стрим?"
            },
            {
                title: "📝 Заявка №4 (Жалоба)",
                description: "Для подачи жалобы на участника или действие:",
                template: "Заявка №4+жалоба на кого+текст жалобы",
                note: "Пример: Заявка №4+участник @ivan+оскорбляет других"
            }
        ];

        let html = `<div style="margin-bottom: 12px;"><button class="back-btn" id="backFromRequestsBtn">◀ Назад в меню</button></div>`;
        html += `<div style="margin-bottom: 12px; background:#ecdcaa; border-radius: 28px; padding: 12px; text-align:center;">
                    📁 Здесь собраны ВСЕ заявки, которые упоминаются в поддержке. Скопируйте шаблон и отправьте в чат.
                 </div>`;
        html += `<div style="max-height: 500px; overflow-y: auto; padding-right: 5px;">`;
        
        requestsList.forEach(req => {
            html += `
                <div class="request-card">
                    <div class="request-title">${escapeHtml(req.title)}</div>
                    <div style="margin-bottom: 8px;">${escapeHtml(req.description)}</div>
                    <div style="background:#e9ddb0; padding: 10px; border-radius: 20px; font-family: monospace; font-size: 0.85rem; word-break: break-all;">
                        ${escapeHtml(req.template)}
                    </div>
                    <div style="font-size: 0.8rem; margin-top: 8px; color:#7a672e;">💡 ${escapeHtml(req.note)}</div>
                    <button class="copy-btn" data-copytext="${escapeHtmlAttr(req.template)}">📋 Скопировать шаблон</button>
                </div>
            `;
        });
        
        // Также добавим напоминание про идеи для развития (из новости)
        html += `
            <div class="request-card">
                <div class="request-title">💡 Идея для развития канала</div>
                <div>Формат для отправки идей в чат:</div>
                <div style="background:#e9ddb0; padding: 10px; border-radius: 20px; font-family: monospace; margin-top: 8px;">
                    Идея для чего+текст идеи
                </div>
                <div style="font-size: 0.8rem; margin-top: 8px;">Пример: Идея для конкурса+провести розыгрыш на 1000 подписчиков</div>
                <button class="copy-btn" data-copytext="Идея для +текст идеи">📋 Скопировать формат</button>
            </div>
        `;
        html += `</div>`;
        return html;
    }

    // Helper для экранирования атрибутов
    function escapeHtmlAttr(str) {
        if (!str) return '';
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    // ---------- СОТРУДНИКИ ----------
