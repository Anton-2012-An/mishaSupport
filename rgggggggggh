    function renderSpecificRule(ruleId) {
        const rulesList = rulesData[ruleId];
        if (!rulesList) return "Правила не найдены.";
        let html = `<ul style="margin:0; padding-left: 20px;">`;
        rulesList.forEach(rule => { html += `<li style="margin-bottom: 8px;">${escapeHtml(rule)}</li>`; });
        html += `</ul>`;
        return html;
    }

    // ---------- НОВОСТИ (две указанные) ----------
    function getNewsHtml() {
        const newsItems = [
            { 
                title: "🔔 НАБОР АГЕНТОВ ПОДДЕРЖКИ", 
                content: "Идёт набор агентов поддержки. Кто желает поучаствовать, тот в вопросах скопирует заявку и отправит в правильный чат, заполнив её.", 
