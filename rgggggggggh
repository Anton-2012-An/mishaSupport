            btnsHtml += `<button class="q-btn" data-qid="${q.id}">${escapeHtml(q.text)}</button>`;
        });
        btnsHtml += `</div><div id="questionAnswerArea" class="answer-area" style="background:#F4EAD5;">🔍 Выберите вопрос, чтобы получить подробный ответ</div>`;
        return btnsHtml;
    }

    function renderComplaintPanel() {
        return `
            <div><button class="back-btn" id="backFromComplaintBtn">◀ Назад в меню</button></div>
            <div class="answer-area" style="margin-top:20px; background:#ffe4ca;">
