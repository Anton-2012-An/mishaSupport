            </div>
        `;
    }

    function renderRulesChoice() {
        return `
            <div style="margin-bottom: 10px;">
                <button class="back-btn" id="backToMainBtn">◀ Назад в меню</button>
            </div>
            <div class="rules-submenu">
                <button class="rule-cat-btn" data-rule="1">📜 Правила канала</button>
                <button class="rule-cat-btn" data-rule="2">🤝 Для агентов поддержки</button>
                <button class="rule-cat-btn" data-rule="3">🛡️ Для модераторов</button>
                <button class="rule-cat-btn" data-rule="4">👑 Для админов</button>
            </div>
            <div id="rulesDisplayArea" class="answer-area" style="background: #f1ecdd;">✨ Выберите раздел правил</div>
        `;
    }

    function renderStaffPanel() {
        return `
            <div style="margin-bottom: 10px;">
                <button class="back-btn" id="backToMainStaffBtn">◀ Назад в меню</button>
            </div>
            <div class="staff-submenu">
                <button class="staff-cat-btn" data-staff="agents">👥 Агенты поддержки</button>
                <button class="staff-cat-btn" data-staff="mods">⚙️ Модераторы</button>
                <button class="staff-cat-btn" data-staff="admins">🔒 Админы</button>
                <button class="staff-cat-btn" data-staff="headadmin">🌟 Главный админ</button>
                <button class="staff-cat-btn" data-staff="creator">🎬 Создатель</button>
            </div>
            <div id="staffAnswerArea" class="answer-area" style="background:#efe3c9; text-align:center;">🗂️ Выберите категорию сотрудников</div>
        `;
    }

    function renderNewsPanel() {
        return getNewsHtml();
    }

    function renderRequestsPanel() {
        return getRequestsHtml();
    }

    function refreshUI() {
        const container = document.getElementById("dynamicContent");
        let innerHtml = "";
        switch(currentMode) {
            case "main": innerHtml = renderMainMenu(); break;
            case "questions": innerHtml = renderQuestionsPanel(); break;
            case "complaint": innerHtml = renderComplaintPanel(); break;
            case "rules": innerHtml = renderRulesChoice(); break;
            case "staff": innerHtml = renderStaffPanel(); break;
            case "news": innerHtml = renderNewsPanel(); break;
            case "requests": innerHtml = renderRequestsPanel(); break;
            default: innerHtml = renderMainMenu();
        }
        container.innerHTML = innerHtml;
        attachPostRenderEvents();
    }

    function attachPostRenderEvents() {
        const questionsBtn = document.getElementById("questionsBtn");
        const complaintBtn = document.getElementById("complaintBtn");
        const rulesBtn = document.getElementById("rulesBtn");
        const staffBtn = document.getElementById("staffBtn");
        const newsBtn = document.getElementById("newsBtn");
        const requestsBtn = document.getElementById("requestsBtn");

        if (questionsBtn) questionsBtn.onclick = () => { currentMode = "questions"; refreshUI(); };
        if (complaintBtn) complaintBtn.onclick = () => { currentMode = "complaint"; refreshUI(); };
        if (rulesBtn) rulesBtn.onclick = () => { currentMode = "rules"; refreshUI(); };
        if (staffBtn) staffBtn.onclick = () => { currentMode = "staff"; refreshUI(); };
        if (newsBtn) newsBtn.onclick = () => { currentMode = "news"; refreshUI(); };
        if (requestsBtn) requestsBtn.onclick = () => { currentMode = "requests"; refreshUI(); };

        const backQuestions = document.getElementById("backFromQuestionsBtn");
        if (backQuestions) backQuestions.onclick = () => { currentMode = "main"; refreshUI(); };
        const backComplaint = document.getElementById("backFromComplaintBtn");
        if (backComplaint) backComplaint.onclick = () => { currentMode = "main"; refreshUI(); };
        const backRulesMain = document.getElementById("backToMainBtn");
        if (backRulesMain) backRulesMain.onclick = () => { currentMode = "main"; refreshUI(); };
        const backStaffMain = document.getElementById("backToMainStaffBtn");
        if (backStaffMain) backStaffMain.onclick = () => { currentMode = "main"; refreshUI(); };
        const backNewsBtn = document.getElementById("backFromNewsBtn");
        if (backNewsBtn) backNewsBtn.onclick = () => { currentMode = "main"; refreshUI(); };
        const backRequestsBtn = document.getElementById("backFromRequestsBtn");
        if (backRequestsBtn) backRequestsBtn.onclick = () => { currentMode = "main"; refreshUI(); };

        // Вопросы
        const qButtons = document.querySelectorAll(".q-btn");
        qButtons.forEach(btn => {
            btn.addEventListener("click", (e) => {
                const qid = parseInt(btn.getAttribute("data-qid"));
                const answerDiv = document.getElementById("questionAnswerArea");
                if (!isNaN(qid) && answersMap[qid]) {
                    if (answerDiv) answerDiv.innerHTML = escapeHtml(getFormattedAnswer(qid)).replace(/\n/g, '<br>');
                } else if(answerDiv) answerDiv.innerHTML = "❓ Ответ не найден. Напишите в чат заявку №3";
            });
        });

        // Правила
        const ruleCatBtns = document.querySelectorAll(".rule-cat-btn");
        ruleCatBtns.forEach(btn => {
            btn.addEventListener("click", (e) => {
                const ruleId = parseInt(btn.getAttribute("data-rule"));
                const displayDiv = document.getElementById("rulesDisplayArea");
                if (displayDiv && ruleId >=1 && ruleId <=4) displayDiv.innerHTML = renderSpecificRule(ruleId);
                else if(displayDiv) displayDiv.innerHTML = "⚠️ Неверный раздел";
            });
        });

        // Сотрудники
        const staffCatBtns = document.querySelectorAll(".staff-cat-btn");
        staffCatBtns.forEach(btn => {
            btn.addEventListener("click", (e) => {
                const staffType = btn.getAttribute("data-staff");
                const info = getStaffInfo(staffType);
                const staffArea = document.getElementById("staffAnswerArea");
                if (staffArea) staffArea.innerHTML = info === "нет данных" ? `<em>📭 ${escapeHtml(info)}</em>` : `<strong>✨ ${escapeHtml(info)}</strong>`;
            });
        });

        // Копирование шаблонов в разделе заявок
        const copyBtns = document.querySelectorAll(".copy-btn");
        copyBtns.forEach(btn => {
            btn.addEventListener("click", (e) => {
                const textToCopy = btn.getAttribute("data-copytext");
                if (textToCopy) {
                    navigator.clipboard.writeText(textToCopy).then(() => {
                        const originalText = btn.innerText;
                        btn.innerText = "✅ Скопировано!";
                        setTimeout(() => { btn.innerText = originalText; }, 1500);
                    }).catch(() => alert("Не удалось скопировать"));
                }
            });
        });
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    refreshUI();
</script>
</body>
</html>
